# Configurações do Flask
SECRET_KEY=sua-chave-secreta-aqui-mude-em-producao
ADMIN_PASSWORD=setordentregas123
PORT=5000
FLASK_DEBUG=false

# ==================== CLOUDFLARE R2 ====================
# Obtenha essas credenciais no painel do Cloudflare R2
# 1. Acesse https://dash.cloudflare.com
# 2. Vá em R2 > Overview
# 3. Clique em "Manage R2 API Tokens"
# 4. Crie um token com permissões de leitura e escrita

# Account ID (encontrado em R2 > Overview)
R2_ACCOUNT_ID=seu-account-id-aqui

# Access Key ID (gerado no API Token)
R2_ACCESS_KEY_ID=seu-access-key-id-aqui

# Secret Access Key (gerado no API Token)
R2_SECRET_ACCESS_KEY=seu-secret-access-key-aqui

# Nome do bucket (crie no painel R2)
R2_BUCKET_NAME=encomendas-fotos

# ==================== CONFIGURAÇÕES DE ARMAZENAMENTO ====================
# Limite total do bucket (padrão: 10GB)
STORAGE_LIMIT_GB=10

# Percentual de alerta para limpeza automática (padrão: 80%)
STORAGE_WARNING_THRESHOLD=0.80

# ==================== INSTRUÇÕES ====================
# 1. Copie este arquivo para .env
# 2. Preencha com suas credenciais do Cloudflare R2
# 3. Crie um bucket no R2 com o nome definido em R2_BUCKET_NAME
# 4. Execute: python app.py
#
# IMPORTANTE: Nunca comite o arquivo .env com credenciais reais!
# O arquivo .gitignore já está configurado para ignorar .env